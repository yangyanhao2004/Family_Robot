# =============================================================================
# Family Robot — Java Backend Configuration Template
# =============================================================================
# How to use:
#   1. Copy this file to application.yml in the same directory
#   2. Fill in your own values (especially the SMTP credentials)
#   3. application.yml is git-ignored and will NOT be committed
#
# All values support environment variable overrides (see README for details).
# =============================================================================

server:
  port: ${SERVER_PORT:8090}
  error:
    include-stacktrace: never
    include-message: always

spring:
  application:
    name: family-robot-backend

  datasource:
    url: ${DB_URL:jdbc:mysql://localhost:3306/family_robot?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai&characterEncoding=UTF-8}
    username: ${DB_USERNAME:root}
    password: ${DB_PASSWORD:123456}
    driver-class-name: com.mysql.cj.jdbc.Driver

  jpa:
    hibernate:
      ddl-auto: update
    show-sql: false
    properties:
      hibernate:
        format_sql: true
    defer-datasource-initialization: true

  sql:
    init:
      mode: always

  mail:
    host: smtp.qq.com
    port: 587
    # IMPORTANT: Replace with your own QQ email and SMTP authorization code
    # Go to QQ Mail → Settings → Accounts → POP3/SMTP Service → Generate Authorization Code
    username: ${SMTP_USERNAME:your_qq_email@qq.com}
    password: ${SMTP_PASSWORD:your_smtp_authorization_code}
    properties:
      mail:
        smtp:
          auth: true
          starttls:
            enable: true

  jackson:
    property-naming-strategy: LOWER_CAMEL_CASE
    serialization:
      write-dates-as-timestamps: false

app:
  jwt:
    secret: ${JWT_SECRET:family-robot-jwt-secret-key-change-in-production-256bits}
    expiration-ms: ${JWT_EXPIRATION:86400000}
  aes:
    secret-key: ${AES_SECRET:family-robot-aes-secret-key-change-in-production-256bits}
  python-backend-url: ${PYTHON_BACKEND_URL:http://192.168.137.90:8080}

logging:
  level:
    com.familyrobot: DEBUG
