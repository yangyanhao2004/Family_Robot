# =============================================================
#  pibot_local_agent-main - API Keys
# =============================================================
#  Copy this file to .env and fill in your keys if needed.
#
#    cp .env.example .env
#
#  All keys are optional. The local voice agent works without
#  them, but the related cloud-backed features will be disabled.
#
#  Variable                Feature unlocked
#  -------------------------------------------------------------
#  OPENWEATHER_API_KEY     Live weather lookups
#  NEWSAPI_KEY             Top news headlines
#  MOONSHOT_API_KEY        Cloud AI answers (Kimi K2)
# =============================================================

OPENWEATHER_API_KEY=
NEWSAPI_KEY=
MOONSHOT_API_KEY=

# Optional remote-control backend settings
FAMILY_ROBOT_WS_URL=
FAMILY_ROBOT_BACKEND_HOST=127.0.0.1
FAMILY_ROBOT_BACKEND_PORT=8080
FAMILY_ROBOT_BACKEND_PATH=/ws
FAMILY_ROBOT_STATUS_INTERVAL=2.0
FAMILY_ROBOT_RECONNECT_INTERVAL=3.0
