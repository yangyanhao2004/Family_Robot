# =============================================================
#  pibot_local_agent-main - API Keys
# =============================================================
#  Copy this file to .env and fill in your keys if needed.
#
#    cp .env.example .env
#
#  All keys are optional. The local voice agent works without
#  them, but the related cloud-backed features will be disabled.
#
#  Variable                Feature unlocked
#  -------------------------------------------------------------
#  OPENWEATHER_API_KEY     Live weather lookups
#  NEWSAPI_KEY             Top news headlines
#  MOONSHOT_API_KEY        Cloud AI answers (Kimi K2)
# =============================================================

OPENWEATHER_API_KEY=
NEWSAPI_KEY=
MOONSHOT_API_KEY=

# Optional remote-control backend settings
FAMILY_ROBOT_WS_URL=
FAMILY_ROBOT_BACKEND_HOST=127.0.0.1
FAMILY_ROBOT_BACKEND_PORT=8080
FAMILY_ROBOT_BACKEND_PATH=/ws
FAMILY_ROBOT_STATUS_INTERVAL=2.0
FAMILY_ROBOT_RECONNECT_INTERVAL=3.0
FAMILY_ROBOT_WS_OPEN_TIMEOUT=8.0
FAMILY_ROBOT_FORCE_LOCAL_ON_BACKEND_DISCONNECT=true

# ── STM32 UART bridge ───────────────────────────────────────────
# Serial port for the USB-UART cable connected to STM32 UART1.
# Leave blank to auto-detect (/dev/ttyUSB0, /dev/ttyACM0, etc.)
FAMILY_ROBOT_SERIAL_PORT=
# Motor speed parameters (encoder pulses per 10 ms, PID closed-loop)
FAMILY_ROBOT_FORWARD_SPEED=50.0
FAMILY_ROBOT_TURN_SPEED=30.0

# Optional Pi WebRTC audio device overrides
FAMILY_ROBOT_WEBRTC_MIC_FORMAT=alsa
FAMILY_ROBOT_WEBRTC_MIC_SOURCE=default
FAMILY_ROBOT_WEBRTC_MIC_DEVICE_NAME=USB PnP Sound Device
FAMILY_ROBOT_WEBRTC_MIC_CHANNELS=1
FAMILY_ROBOT_WEBRTC_MIC_SAMPLE_RATE=48000
FAMILY_ROBOT_WEBRTC_SPK_FORMAT=alsa
FAMILY_ROBOT_WEBRTC_SPK_TARGET=default
FAMILY_ROBOT_WEBRTC_SPK_DEVICE_NAME=bcm2835 Headphones
FAMILY_ROBOT_WEBRTC_SPK_CHANNELS=1
FAMILY_ROBOT_WEBRTC_SPK_SAMPLE_RATE=48000

# ── Camera ────────────────────────────────────────────────────────
FAMILY_ROBOT_CAMERA_ENABLED=true
FAMILY_ROBOT_CAMERA_WIDTH=640
FAMILY_ROBOT_CAMERA_HEIGHT=360
FAMILY_ROBOT_CAMERA_FPS=10
FAMILY_ROBOT_CAMERA_JPEG_QUALITY=70

# ── Misc ──────────────────────────────────────────────────────────
FAMILY_ROBOT_VERBOSE=
FAMILY_ROBOT_SESSION_RELEASE_DELAY=1.5
